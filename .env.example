# DCF Herramientas Web — Variables de entorno
# Copiar este archivo a .env y completar los valores

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Google Sheets (whitelist de emails) ─────────────────────────────────────
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_GID=0
# JSON de service account inline (una línea, con comillas escapadas)
# O bien: ruta a un archivo JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-al-menos-32-caracteres-aleatorios
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── APIs de datos ────────────────────────────────────────────────────────────
FINNHUB_TOKEN=your-finnhub-api-token

# ── Ruta a datos compartidos con app Streamlit ─────────────────────────────
# Carpeta que contiene: BD BONOS HD.xlsx, Letras Activas.xlsx, BD ONs.xlsx, etc.
STREAMLIT_DATA_PATH=G:\.shortcut-targets-by-id\1ftoIZqhxjIK-zxyM2xIG9xFIX4GG9BvJ\DCF\Marketing\Instagram\Scripts Python\App DCF Dani\data

# ── App settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
ALLOWED_ORIGINS=http://localhost:8000,https://app.dcfinversiones.com
